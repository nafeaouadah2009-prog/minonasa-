{
  "expo": {
    "name": "أذكار وقرآن",
    "slug": "athkar-qraan", 
    "owner": "nafeaouadah2009s-team",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0F1B2D"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.nafea.adhkarquran",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "نحتاج موقعك لعرض مواقيت الصلاة واتجاه القبلة الدقيقة لمنطقتك"
      }
    },
    "android": {
      "package": "com.nafea.adhkarquran",
      "adaptiveIcon": {
        "backgroundColor": "#0F1B2D"
      },
      "permissions": ["ACCESS_COARSE_LOCATION", "ACCESS_FINE_LOCATION"]
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "نحتاج موقعك لعرض مواقيت الصلاة واتجاه القبلة الدقيقة لمنطقتك"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "f62696b7-35f4-4abf-8cf5-4c9078100eac"
      }
    }
  }
}
